# ============================================
# WanderP AI Engine 环境变量配置
# ============================================

# ---- 应用基础配置 ----
APP_NAME=wanderp-ai-engine
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ---- 服务端口 ----
HOST=0.0.0.0
PORT=8000

# ---- 通义千问 LLM 配置 ----
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
LLM_MODEL=qwen-max
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ---- 通义 Embedding 配置 ----
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1024

# ---- Milvus 向量数据库 ----
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus
MILVUS_DB_NAME=wanderp
MILVUS_COLLECTION_NAME=travel_knowledge

# ---- Redis 缓存 ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL=3600

# ---- 和风天气 API ----
QWEATHER_API_KEY=your-qweather-api-key
QWEATHER_BASE_URL=https://devapi.qweather.com/v7

# ---- 高德地图 API ----
AMAP_API_KEY=your-amap-api-key
AMAP_SECRET_KEY=your-amap-secret-key

# ---- 聚合数据 API ----
JUHE_API_KEY=your-juhe-api-key

# ---- 飞猪开放平台 API ----
FEIZHU_APP_KEY=your-feizhu-app-key
FEIZHU_APP_SECRET=your-feizhu-app-secret

# ---- CORS 配置 ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
