# =============================================================================
# WanderP - 环境变量配置模板
# =============================================================================
# 使用方式:
#   cp .env.example .env
#   然后根据实际环境修改 .env 中的值
# =============================================================================

# ---------------------------------------------------------------------------
# 应用配置
# ---------------------------------------------------------------------------
APP_ENV=development
# 可选值: development, staging, production

# ---------------------------------------------------------------------------
# PostgreSQL 配置
# ---------------------------------------------------------------------------
POSTGRES_USER=wanderp
POSTGRES_PASSWORD=wanderp_dev_2024
POSTGRES_DB=wanderp
POSTGRES_PORT=5432
# 完整DSN（服务内部使用，由docker-compose自动拼接）
# POSTGRES_DSN=postgres://wanderp:wanderp_dev_2024@localhost:5432/wanderp?sslmode=disable

# ---------------------------------------------------------------------------
# Redis 配置
# ---------------------------------------------------------------------------
REDIS_PASSWORD=wanderp_redis_2024
REDIS_PORT=6379
# REDIS_URL=redis://:wanderp_redis_2024@localhost:6379/0

# ---------------------------------------------------------------------------
# Milvus 配置
# ---------------------------------------------------------------------------
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
MILVUS_MINIO_ACCESS_KEY=minioadmin
MILVUS_MINIO_SECRET_KEY=minioadmin

# ---------------------------------------------------------------------------
# InfluxDB 配置
# ---------------------------------------------------------------------------
INFLUXDB_USER=wanderp
INFLUXDB_PASSWORD=wanderp_influx_2024
INFLUXDB_PORT=8086
INFLUXDB_ORG=wanderp
INFLUXDB_BUCKET=wanderp
INFLUXDB_TOKEN=
# 初始化后从InfluxDB UI获取Token填入

# ---------------------------------------------------------------------------
# MongoDB 配置
# ---------------------------------------------------------------------------
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=wanderp_mongo_2024
MONGO_PORT=27017
# MONGO_URL=mongodb://root:wanderp_mongo_2024@localhost:27017/wanderp?authSource=admin

# ---------------------------------------------------------------------------
# MinIO 配置
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=wanderp_admin
MINIO_ROOT_PASSWORD=wanderp_minio_2024
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------------------------------------------------------------------------
# EMQX 配置
# ---------------------------------------------------------------------------
EMQX_MQTT_PORT=1883
EMQX_WS_PORT=8083
EMQX_WSS_PORT=8084
EMQX_DASHBOARD_PORT=18083
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=wanderp_emqx_2024
EMQX_MQTT_USER=
EMQX_MQTT_PASSWORD=

# ---------------------------------------------------------------------------
# JWT 认证配置
# ---------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_please_use_a_long_random_string
JWT_EXPIRATION=24h

# ---------------------------------------------------------------------------
# 服务端口配置
# ---------------------------------------------------------------------------
GATEWAY_PORT=8080
USER_SERVICE_PORT=8001
PLANNER_SERVICE_PORT=8002
MAP_SERVICE_PORT=8003
NOTIFICATION_SERVICE_PORT=8004
AI_ENGINE_PORT=8005

# ---------------------------------------------------------------------------
# 第三方API密钥
# ---------------------------------------------------------------------------

# 高德地图 API Key（地图服务、POI搜索、路线规划）
AMAP_API_KEY=

# OpenAI API 配置（AI引擎使用）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# AI模型配置
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o

# 天气API Key
WEATHER_API_KEY=

# 飞猪API Key（机票、酒店搜索）
FEIZHU_API_KEY=

# 聚合数据API Key（餐饮推荐等）
JUHE_API_KEY=

# ---------------------------------------------------------------------------
# 日志配置
# ---------------------------------------------------------------------------
LOG_LEVEL=debug
# 可选值: debug, info, warn, error
LOG_FORMAT=json
# 可选值: json, text

# ---------------------------------------------------------------------------
# 其他配置
# ---------------------------------------------------------------------------
TZ=Asia/Shanghai
